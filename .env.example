# ============================================================
# HƯỚNG DẪN CÀI ĐẶT API KEY
# ============================================================
# 1. Sao chép file này thành file .env:
#       copy .env.example .env        (Windows)
#       cp .env.example .env          (Linux/Mac)
#
# 2. Điền Gemini API Key của bạn vào dòng bên dưới
#    (Lấy key tại: https://aistudio.google.com/app/apikey)
#
# 3. KHÔNG commit file .env lên Git (đã được gitignore)
# ============================================================

GOOGLE_API_KEY=your_gemini_api_key_here
